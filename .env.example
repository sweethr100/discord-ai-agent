# Discord
DISCORD_TOKEN=
DISCORD_GUILD_ID=

# Provider: openai, gemini, anthropic, local
AI_PROVIDER=openai

# Common AI behavior
SYSTEM_PROMPT=너는 디스코드 서버에서 동작하는 친절하고 유용한 AI 에이전트다. 기본적으로 한국어로 짧고 명확하게 답하라. 사용자가 자세히 요청할 때만 길게 설명하라.
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=
REQUEST_TIMEOUT_SECONDS=60

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Anthropic Claude
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4-5-sonnet-latest

# OpenAI-compatible local server, for example Ollama, LM Studio, vLLM
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1
LOCAL_API_KEY=
